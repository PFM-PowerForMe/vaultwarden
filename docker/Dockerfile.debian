FROM --platform=$TARGETPLATFORM ghcr.io/pfm-powerforme/vaultwarden:main

RUN ln -snf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && echo Asia/Shanghai > /etc/timezone

RUN apt-get update && apt-get install -y \
        --no-install-recommends \
        cron tar s3cmd && \
    apt-get clean

RUN echo '* * * * * root sh -c "/backup.sh"' >> /etc/crontab

COPY docker/backup.sh /backup.sh
COPY docker/start-debian.sh /start-debian.sh

RUN chmod +x /backup.sh && chmod +x /start-debian.sh

CMD ["/start-debian.sh"]