FROM --platform=$TARGETPLATFORM ghcr.io/pfm-powerforme/vaultwarden:main-alpine

RUN apk --no-cache add \
        cron

RUN ln -snf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && echo Asia/Shanghai > /etc/timezone

RUN echo '* * * * * root sh -c "/backup.sh"' >> /etc/crontab

RUN RUN update-rc.d cron enable && service cron start

COPY docker/backup.sh /backup.sh

RUN chmod +x /backup.sh